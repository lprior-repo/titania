# =====================================================================
# Titania workspace gitignore.
# MOON CI/CD is the absolute foundation; this ignore keeps the repo
# clean of Moon / Cargo / IDE / OS scratch state while preserving
# everything dogfooded into the gate.
# =====================================================================

# ----- Cargo / Rust -----------------------------------------------
# Build artifacts.
/target/
**/fixtures/*/target/
**/fixtures/**/target/

# rustfmt backup files (cargo fmt renames the original to .rs.bk
# mid-rewrite, then overwrites).
**/*.rs.bk

# Cargo's incremental / fingerprint caches.
**/*.d
**/*.rmeta
**/*.rlib

# Cargo.lock is committed for this workspace (slice 2 adds a bin
# crate, after which Cargo.lock is required for reproducible builds).
# Keep tracking it; uncomment if the project becomes pure-library-only.
# /Cargo.lock

# ----- Moon ------------------------------------------------------
# Local cache: task hashes, run reports, bazel-remote hooks.
/.moon/cache/

# Titania lane artifacts and build caches are regenerated by `titania-check`
# and Moon lane commands. Keep them out of git status and Moon's git-backed
# input hashing.
/.titania/cache/
/.titania/out/
# Hermetic CARGO_HOME / RUSTUP_HOME are machine-specific local state for the
# v1-spec §9.5 hermeticity posture; operators symlink or populate them.
/.titania/hermetic/
/crates/titania-lanes/.titania/
/crates/titania-check/.titania/

# ----- Beads -----------------------------------------------------
# Dolt data plane (issue tracker lives outside git history).
/.dolt/
/*.db
/.beads-credential-key
/.beads/proxieddb/
# Beads agent scratch / progress notes (local, non-canonical).
/.bead-progress/

# ----- IDE / Editor ---------------------------------------------
# IntelliJ / JetBrains
/.idea/
*.iml
*.iws

# VS Code
/.vscode/

# Vim
*.swp
*.swo
*~
.viminfo

# Emacs
\#*\#
/.dir-locals.el

# ----- OS -------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.fuse_hidden*
.Trash-*

# ----- Coverage / Profiling ------------------------------------
/coverage/
/tarpaulin-report.html
*.lcov
*.profraw
*.gcda
*.gcno

# ----- Secrets / Local Env -------------------------------------
/.env
/.env.local
/.envrc

# ----- Logs ----------------------------------------------------
*.log
logs/


# ----- Stray bench artifacts ------------------------------------
/formal_setup_smoke
/receipt_schema

# ----- Tool caches (kept off the wire) -------------------------
/.sccache/
/.worktrees/

# ----- cargo-fuzz scratch artifacts ----------------------------
# cargo-fuzz writes coverage, corpus, and dictionary files under
# fuzz/target/. The directory is regenerated on every fuzz run, so
# it should never be committed. Per the fuzz package's stub-mode
# design (libfuzzer-sys default-features = false), `cargo check`
# also writes a target directory here on first build.
fuzz/target/

# ----- cargo-kani + cargo-mutants scratch artifacts ---------
# cargo-kani writes its harness inventory to <crate>/kani-list.json
# when invoked with `cargo kani list --format json`. cargo-mutants
# writes scratch to mutants.out/. Both are regenerated on every lane
# run, so they should never be committed.
**/kani-list.json
**/mutants.out/
